// This is your Prisma schema file
// Member 5 is the sole maintainer of this file
// Run: npx prisma migrate dev --name <description> after any changes

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// Member 1 — 用户系统
// ─────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  username     String   @unique
  display_name String?
  avatar_url   String?
  bio          String?
  role         Role     @default(user)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  // Relations
  cats                     Cat[]
  posts                    Post[]
  post_likes               PostLike[]
  comments                 Comment[]
  adopter_preferences      AdopterPreference?
  adoption_applications    AdoptionApplication[]
  adoption_swipes          AdoptionSwipe[]
  owner_health_records     OwnerHealthRecord[]
  health_share_permissions HealthSharePermission[]
  followers                UserFollow[]            @relation("following")
  following                UserFollow[]            @relation("follower")
  conversations_as_user    Conversation[]          @relation("user_conversations")
  conversations_as_org     Conversation[]          @relation("org_conversations")
  sent_messages            Message[]

  @@map("users")
}

enum Role {
  user
  rescue_staff
  clinic_staff
  admin
}

// ─────────────────────────────────────────
// Member 3 — 关注关系
// ─────────────────────────────────────────

model UserFollow {
  id           String   @id @default(uuid())
  follower_id  String
  following_id String
  created_at   DateTime @default(now())

  follower  User @relation("follower", fields: [follower_id], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [following_id], references: [id], onDelete: Cascade)

  @@unique([follower_id, following_id])
  @@map("user_follows")
}

// ─────────────────────────────────────────
// Member 5 — 救助机构 / 诊所
// ─────────────────────────────────────────

model Organization {
  id          String   @id @default(uuid())
  name        String
  type        OrgType
  email       String   @unique
  password    String
  phone       String?
  address     String?
  logo_url    String?
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  cats           Cat[]
  clinic_reports ClinicHealthReport[]

  @@map("organizations")
}

enum OrgType {
  rescue
  clinic
}

// ─────────────────────────────────────────
// Member 2 — 猫咪档案 + 领养模块
// ─────────────────────────────────────────

enum CatStatus {
  available
  adopted
  unavailable
}

model Cat {
  id           String    @id @default(uuid())
  name         String
  breed        String?
  age_months   Int?
  gender       String?
  color        String?
  description  String?
  photo_url    String?
  status       CatStatus @default(available)
  owner_id     String?
  org_id       String?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  owner                    User?                   @relation(fields: [owner_id], references: [id])
  organization             Organization?           @relation(fields: [org_id], references: [id])
  tags                     CatTag[]
  requirements             CatRequirement[]
  updates                  CatUpdate[]
  adoption_applications    AdoptionApplication[]
  adoption_swipes          AdoptionSwipe[]
  owner_health_records     OwnerHealthRecord[]
  clinic_reports           ClinicHealthReport[]
  health_share_permissions HealthSharePermission[]

  @@map("cats")
}

model CatTag {
  id         String   @id @default(uuid())
  cat_id     String
  tag        String
  created_at DateTime @default(now())

  cat Cat @relation(fields: [cat_id], references: [id], onDelete: Cascade)

  @@map("cat_tags")
}

model CatRequirement {
  id          String   @id @default(uuid())
  cat_id      String
  description String
  created_at  DateTime @default(now())

  cat Cat @relation(fields: [cat_id], references: [id], onDelete: Cascade)

  @@map("cat_requirements")
}

model CatUpdate {
  id         String   @id @default(uuid())
  cat_id     String
  content    String
  photo_url  String?
  created_at DateTime @default(now())

  cat Cat @relation(fields: [cat_id], references: [id], onDelete: Cascade)

  @@map("cat_updates")
}

model AdopterPreference {
  id               String   @id @default(uuid())
  user_id          String   @unique
  preferred_age    String?
  preferred_gender String?
  preferred_breed  String?
  preferred_color  String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("adopter_preferences")
}

model AdoptionApplication {
  id         String            @id @default(uuid())
  user_id    String
  cat_id     String
  status     ApplicationStatus @default(pending)
  message    String?
  created_at DateTime          @default(now())
  updated_at DateTime          @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  cat  Cat  @relation(fields: [cat_id], references: [id], onDelete: Cascade)

  @@map("adoption_applications")
}

// 滑动记录：右滑喜欢 / 左滑跳过
model AdoptionSwipe {
  id         String   @id @default(uuid())
  user_id    String
  cat_id     String
  liked      Boolean
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  cat  Cat  @relation(fields: [cat_id], references: [id], onDelete: Cascade)

  @@unique([user_id, cat_id])
  @@map("adoption_swipes")
}

enum ApplicationStatus {
  pending
  approved
  rejected
}

// ─────────────────────────────────────────
// Member 3 — 社区模块
// ─────────────────────────────────────────

model Post {
  id         String   @id @default(uuid())
  user_id    String
  content    String
  image_url  String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user     User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  likes    PostLike[]
  comments Comment[]

  @@map("posts")
}

model PostLike {
  id         String   @id @default(uuid())
  user_id    String
  post_id    String
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  post Post @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@unique([user_id, post_id])
  @@map("post_likes")
}

model Comment {
  id         String   @id @default(uuid())
  user_id    String
  post_id    String
  content    String
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  post Post @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@map("comments")
}

// ─────────────────────────────────────────
// Member 5 — 健康管理模块
// ─────────────────────────────────────────

model OwnerHealthRecord {
  id          String   @id @default(uuid())
  cat_id      String
  user_id     String
  record_type String
  description String
  date        DateTime
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  cat  Cat  @relation(fields: [cat_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("owner_health_records")
}

model ClinicHealthReport {
  id          String   @id @default(uuid())
  cat_id      String
  org_id      String
  report_type String
  description String
  file_url    String?
  date        DateTime
  created_at  DateTime @default(now())

  cat          Cat          @relation(fields: [cat_id], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)

  @@map("clinic_health_reports")
}

model HealthSharePermission {
  id         String   @id @default(uuid())
  cat_id     String
  user_id    String
  org_id     String
  is_allowed Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  cat  Cat  @relation(fields: [cat_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([cat_id, org_id])
  @@map("health_share_permissions")
}

// ─────────────────────────────────────────
// Member 6 — 聊天功能
// ─────────────────────────────────────────

model Conversation {
  id         String   @id @default(uuid())
  user_id    String
  org_id     String
  created_at DateTime @default(now())

  user     User      @relation("user_conversations", fields: [user_id], references: [id], onDelete: Cascade)
  org      User      @relation("org_conversations", fields: [org_id], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([user_id, org_id])
  @@map("conversations")
}

model Message {
  id              String   @id @default(uuid())
  conversation_id String
  sender_id       String
  content         String
  created_at      DateTime @default(now())

  conversation Conversation        @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  sender       User                @relation(fields: [sender_id], references: [id], onDelete: Cascade)
  attachments  MessageAttachment[]

  @@map("messages")
}

model MessageAttachment {
  id         String   @id @default(uuid())
  message_id String
  file_url   String
  file_type  String
  created_at DateTime @default(now())

  message Message @relation(fields: [message_id], references: [id], onDelete: Cascade)

  @@map("message_attachments")
}
