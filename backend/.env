# 后端服务
PORT=3000
NODE_ENV=development

# PostgreSQL 数据库（修改为你自己的密码）
DATABASE_URL="postgresql://postgres:postgres123@localhost:5432/catface_dev"

# JWT
JWT_SECRET=替换为随机字符串至少32位
JWT_EXPIRES_IN=7d

# Cloudinary（图片存储，去 cloudinary.com 注册免费账号）
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
