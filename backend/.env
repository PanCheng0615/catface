# 后端服务
PORT=3000
NODE_ENV=development

# PostgreSQL 数据库（填入你自己本地的密码）
# Windows 用户: postgresql://postgres:你的密码@localhost:5432/catface_dev
# Mac 用户:     postgresql://你的Mac用户名@localhost:5432/catface_dev
DATABASE_URL="postgresql://postgres:你的密码@localhost:5432/catface_dev"

# JWT（随机字符串，至少32位，可以乱打键盘）
JWT_SECRET=替换为随机字符串至少32位
JWT_EXPIRES_IN=7d

# Cloudinary（图片云存储，去 cloudinary.com 注册免费账号获取）
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
