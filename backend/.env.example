# 后端服务
PORT=3000
NODE_ENV=development

# PostgreSQL 数据库
DATABASE_URL="postgresql://用户名:密码@localhost:5432/catface_dev"

# JWT
JWT_SECRET=替换为随机字符串至少32位
JWT_EXPIRES_IN=7d

# Cloudinary（图片存储）
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# KAMFace（猫脸识别）
KAM_FACE_BASE=../KAM_Face_pipeline_demo
KAM_FACE_WEIGHTS_DIR=../KAM_Face_pipeline_demo/weights
KAM_FACE_DEVICE=cpu
KAM_FACE_THRESHOLD=0.8